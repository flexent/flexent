{
    "name": "@luminable/monorepo",
    "version": "1.0.3",
    "description": "Luminable — frameworkless OOP toolkit for building scalable applications",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "pre-commit": [
        "lint"
    ],
    "scripts": {
        "clean": "run-s clean:workspaces clean:ts",
        "clean:workspaces": "npm run clean --workspaces --if-present",
        "clean:ts": "rm -rf packages/*/{out,*.tsbuildinfo}",
        "dev": "npm run clean && run-p dev:*",
        "dev:ts": "tsc -b -w",
        "compile:ts": "tsc -b",
        "lint": "eslint . --fix",
        "test": "npm run test --workspaces --if-present",
        "version": "run-s version:bump",
        "version:bump": "node ./tools/bump-version.mjs && git add **/package.json",
        "postversion": "npm run publish:workspaces && git push origin $(git branch --show-current) --tags",
        "publish:workspaces": "npm publish $(node ./tools/ls-publish-workspaces.mjs) --access=public"
    },
    "devDependencies": {
        "@fastify/pre-commit": "^2.2.1",
        "@luminable/eslint-config": "file:packages/eslint-config",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.0.3",
        "eslint": "^9.39.2",
        "mocha": "^11.7.5",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3"
    }
}
