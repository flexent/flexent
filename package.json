{
    "name": "@flexent/monorepo",
    "version": "2.0.2",
    "description": "Flexent — frameworkless OOP toolkit for building scalable applications",
    "author": "Boris Okunskiy",
    "license": "MIT",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "pre-commit": [
        "lint"
    ],
    "scripts": {
        "clean": "run-s clean:workspaces clean:ts",
        "clean:workspaces": "npm run clean --workspaces --if-present",
        "clean:ts": "rm -rf packages/*/{out,*.tsbuildinfo}",
        "dev": "npm run clean && run-p dev:*",
        "dev:ts": "tsc -b -w",
        "compile:ts": "tsc -b",
        "lint": "eslint . --fix",
        "test": "npm run tst --workspaces --if-present",
        "version": "run-s clean compile:ts version:bump",
        "version:bump": "bump-version && git add **/package.json",
        "postversion": "npm run publish:workspaces && git push && git push --tags",
        "publish:workspaces": "npm publish $(ls-publish-workspaces) --access=public"
    },
    "devDependencies": {
        "@fastify/pre-commit": "^2.2.1",
        "@flexent/eslint-config": "file:packages/eslint-config",
        "@flexent/repo-tools": "file:packages/repo-tools",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.0.3",
        "eslint": "^9.39.2",
        "mocha": "^12.0.0-beta-9.2",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3"
    }
}
